# ============================================
# HIVEMIND GITIGNORE — PROTECTION MODEL
# ============================================
# NEVER committed (client sensitive):
#   clients/<name>/  → repo paths, credentials
#   memory/<name>/   → KB data, vectors, SQLite DBs
#                       investigations, profiles, indexes
# SAFE to commit (framework only):
#   clients/_example/ → template for new clients
#   memory/README.md  → documentation
#   All Python source, tests, docs, Makefile
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# ============================================
# SENSITIVE — Client data (repos, secrets, profiles)
# ============================================
# Ignore all client data except the example template
clients/*
!clients/_example/

# Ignore all memory data except the README
memory/*
!memory/README.md

*.db
*.sqlite
*.sqlite3

# ============================================
# Benchmark results (generated, not source)
# ============================================
benchmarks/results_*.md

# ============================================
# HTI (HiveMind Tree Intelligence)
# ============================================
hivemind_mcp/hti/__pycache__/

# ============================================
# Sync state and logs (client-specific, sensitive)
# ============================================
memory/*/sync_state.json
memory/*/sync_log.txt

# ============================================
# Investigation memory (client incident data)
# ============================================
memory/*/investigations/

# ============================================
# Environment and local config
# ============================================
.env
.env.*
*.local
CLAUDE.local.md

# ============================================
# VS Code extension build artifacts (legacy)
# ============================================
vscode-extension-legacy/node_modules/
vscode-extension-legacy/out/
vscode-extension-legacy/*.vsix

# OS
Thumbs.db
Desktop.ini
.DS_Store

# IDE
.idea/
.vscode/*
!.vscode/mcp.json.example
*.swp
*.swo
*~

# Cloned repos (if stored locally)
repos/

# Logs
*.log

# Test cache
.pytest_cache/
